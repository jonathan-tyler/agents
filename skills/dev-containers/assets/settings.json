{
    "chat.tools.terminal.autoApprove": {
        // Allow common read-only/navigation commands
        "cd": true,
        "echo": true,
        "ls": true,
        "dir": true,
        "pwd": true,
        "cat": true,
        "head": true,
        "tail": true,
        "findstr": true,
        "wc": true,
        "tr": true,
        "cut": true,
        "cmp": true,
        "which": true,
        "basename": true,
        "dirname": true,
        "realpath": true,
        "readlink": true,
        "stat": true,
        "file": true,
        "od": true,
        "du": true,
        "df": true,
        "sleep": true,
        "nl": true,
        "grep": true,
        "column": true,
        "date": true,
        "find": true,
        "rg": true,
        "sed": true,
        "sort": true,
        "tree": true,
        "/^xxd$/": true,
        "/^xxd\\b(\\s+-\\S+)*\\s+[^-\\s]\\S*$/": true,
        // Allow read-only PowerShell utilities
        "Get-ChildItem": true,
        "Get-Content": true,
        "Get-Date": true,
        "Get-Random": true,
        "Get-Location": true,
        "Set-Location": true,
        "Write-Host": true,
        "Write-Output": true,
        "Out-String": true,
        "Split-Path": true,
        "Join-Path": true,
        "Start-Sleep": true,
        "Where-Object": true,
        "/^Select-[a-z0-9]/i": true,
        "/^Measure-[a-z0-9]/i": true,
        "/^Compare-[a-z0-9]/i": true,
        "/^Sort-[a-z0-9]/i": true,
        // Allow read-only package/container inspection commands
        "/^npm\\s+(ls|list|outdated|view|info|show|explain|why|root|prefix|bin|search|doctor|fund|repo|bugs|docs|home|help(-search)?)\\b/": true,
        "/^npm\\s+config\\s+(list|get)\\b/": true,
        "/^npm\\s+pkg\\s+get\\b/": true,
        "/^npm\\s+audit$/": true,
        "/^npm\\s+cache\\s+verify\\b/": true,
        "npm ci": true,
        "/^yarn\\s+(list|outdated|info|why|bin|help|versions)\\b/": true,
        "/^yarn\\s+licenses\\b/": true,
        "/^yarn\\s+audit\\b(?!.*\\bfix\\b)/": true,
        "/^yarn\\s+config\\s+(list|get)\\b/": true,
        "/^yarn\\s+cache\\s+dir\\b/": true,
        "/^yarn\\s+install\\s+--frozen-lockfile\\b/": true,
        "/^pnpm\\s+(ls|list|outdated|why|root|bin|doctor)\\b/": true,
        "/^pnpm\\s+licenses\\b/": true,
        "/^pnpm\\s+audit\\b(?!.*\\bfix\\b)/": true,
        "/^pnpm\\s+config\\s+(list|get)\\b/": true,
        "/^pnpm\\s+install\\s+--frozen-lockfile\\b/": true,
        // Allow testing commands
        "/^npm\\s+(test|t)\\b/": true,
        "/^npm\\s+run\\s+test(?::[^\\s]+)?\\b/": true,
        "/^yarn\\s+(test|run\\s+test(?::[^\\s]+)?)\\b/": true,
        "/^pnpm\\s+(test|run\\s+test(?::[^\\s]+)?)\\b/": true,
        "/^bun\\s+test\\b/": true,
        "/^node\\s+--test\\b/": true,
        "/^go\\s+test\\b/": true,
        "/^dotnet\\s+test\\b/": true,
        "/^python(3)?\\s+-m\\s+(pytest|unittest)\\b/": true,
        "/^pytest\\b/": true,
        "/^tox\\b/": true,
        "/^nox\\b/": true,
        "/^docker\\s+(ps|images|info|version|inspect|logs|top|stats|port|diff|search|events)\\b/": true,
        "/^docker\\s+(container|image|network|volume|context|system)\\s+(ls|ps|inspect|history|show|df|info)\\b/": true,
        "/^docker\\s+compose\\s+(ps|ls|top|logs|images|config|version|port|events)\\b/": true,
        // Block risky flags/options for otherwise safe commands
        "/^column\\b.*\\s-c\\s+[0-9]{4,}/": false,
        "/^date\\b.*\\s(-s|--set)\\b/": false,
        "/^find\\b.*\\s-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
        "/^rg\\b.*\\s(--pre|--hostname-bin)\\b/": false,
        "/^sed\\b.*\\s(-[a-zA-Z]*(e|f)[a-zA-Z]*|--expression|--file)\\b/": false,
        "/^sed\\b.*s\\/.*\\/.*\\/[ew]/": false,
        "/^sed\\b.*;W/": false,
        "/^sort\\b.*\\s-(o|S)\\b/": false,
        "/^tree\\b.*\\s-o\\b/": false,
        // Block destructive file operations (cross-platform)
        "rm": false,
        "rmdir": false,
        "del": false,
        "erase": false,
        "rd": false,
        "/^rm\\s+-rf/": false,
        // Block PowerShell destructive commands
        "Remove-Item": false,
        "Remove-ItemProperty": false,
        "/^Remove-/": false,
        "Clear-Content": false,
        "Clear-Item": false,
        "/^Format-/": false,
        // Block dangerous git operations
        "/^git\\s+(clean|reset\\s+--hard|push\\s+--force)/": false,
        "/^git\\s+push\\s+.*--force-with-lease\\b/": false,
        "/^git\\s+(branch\\s+-D|tag\\s+-d|push\\s+--mirror|reflog\\s+expire|gc\\s+--prune=now)\\b/": false,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+branch\\b.*\\s-(d|D|m|M|-delete|-force)\\b/": false,
        // Block system/process modifications (Linux/Mac and generic shell)
        "sudo": false,
        "chmod": false,
        "chown": false,
        "kill": false,
        "killall": false,
        "dd": false,
        "ps": false,
        "top": false,
        "jq": false,
        "xargs": false,
        "eval": false,
        // Block system/process modifications (Windows/PowerShell)
        "Stop-Process": false,
        "spps": false,
        "taskkill": false,
        "taskkill.exe": false,
        "Stop-Computer": false,
        "Restart-Computer": false,
        "Set-ExecutionPolicy": false,
        "Set-ItemProperty": false,
        "sp": false,
        "Set-Acl": false,
        "ri": false,
        "takeown": false,
        "icacls": false,
        "cacls": false,
        "attrib": false,
        // Block package uninstalls/removals
        "/^npm\\s+(uninstall|un|prune)\\b/": false,
        "/^pnpm\\s+(remove|rm|uninstall)\\b/": false,
        "/^yarn\\s+remove\\b/": false,
        "/^bun\\s+remove\\b/": false,
        "/^pip\\s+(uninstall|cache\\s+purge)\\b/": false,
        "/^pipx\\s+uninstall\\b/": false,
        "/^cargo\\s+(clean|uninstall)\\b/": false,
        "/^brew\\s+(uninstall|cleanup)\\b/": false,
        "/^scoop\\s+uninstall\\b/": false,
        "/^dnf\\s+(remove|erase|autoremove)\\b/": false,
        "/^yum\\s+(remove|erase|autoremove)\\b/": false,
        "/^apt(-get)?\\s+(remove|purge|autoremove|clean|autoclean)\\b/": false,
        "/^pacman\\s+(-R|-Sc|-Scc)\\b/": false,
        "/^zypper\\s+(remove|rm|clean)\\b/": false,
        "/^apk\\s+del\\b/": false,
        "/^nix-env\\s+-e\\b/": false,
        "/^composer\\s+remove\\b/": false,
        "/^gem\\s+uninstall\\b/": false,
        "/^poetry\\s+cache\\s+clear\\b/": false,
        "Uninstall-Package": false,
        "Uninstall-Module": false,
        "/^choco\\s+uninstall/": false,
        "/^winget\\s+(uninstall|cleanup)\\b/": false,
        // Block network downloads (prompt injection risk)
        "curl": false,
        "wget": false,
        "Invoke-WebRequest": false,
        "Invoke-RestMethod": false,
        "iwr": false,
        "irm": false,
        // Block code execution risks (PowerShell)
        "Invoke-Expression": false,
        "iex": false,
        "/^&\\s+/": false,
        // Block registry modifications (Windows)
        "/^reg\\s+(delete|add)/": false,
        // Block network configuration (Windows)
        "/^netsh\\s/": false,
        // Block WMI operations (Windows)
        "/^wmic\\s/": false,
        // Block container destructive operations
        "/^docker\\s+(rm|rmi|system\\s+prune|container\\s+prune|image\\s+prune|volume\\s+prune)\\b/": false,
        "/^docker-compose\\s+down/": false,
        "/^docker-compose\\s+rm\\b/": false,
        "/^podman\\s+(rm|rmi|system\\s+prune|container\\s+prune|image\\s+prune|volume\\s+prune)\\b/": false,
        "/^podman-compose\\s+down\\b/": false,
        // Block cluster destructive operations
        "/^kubectl\\s+delete\\b/": false,
        "/^helm\\s+uninstall\\b/": false,
        // Block host service/user destructive operations
        "/^(userdel|deluser|groupdel)\\b/": false,
        "/^systemctl\\s+(disable|mask|stop|reboot|poweroff)\\b/": false,
        "/^(shutdown|reboot|poweroff|halt)\\b/": false,
        // Block firewall/network rule destructive operations
        "/^(iptables|nft|ufw|firewall-cmd)\\b/": false,
        // Block format/partition operations
        "mkfs": false,
        "/^mkfs(\\.[a-z0-9]+)?\\b/": false,
        "/^dd\\s+if=.*\\s+of=\\/dev\\//": false,
        "fdisk": false,
        "parted": false,
        "diskpart": false,
        "Format-Volume": false,
        "Clear-Disk": false
    }
}